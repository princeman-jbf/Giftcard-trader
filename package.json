{
  "name": "giftcard-trader",
  "version": "1.0.0",
  "description": "A mobile app for trading gift cards securely and efficiently",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "eject": "expo eject",
    "build:ios": "eas build --platform ios",
